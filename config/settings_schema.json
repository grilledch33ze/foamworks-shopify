 [
   {
    "name": "theme_info",
    "theme_name": "Custom Theme",
    "theme_author": "Munashe Chimutanda",
    "theme_version": "1.0.0",
    "theme_documentation_url": "https://github.com/shopify/cli",
    "theme_support_url": "https://github.com/shopify/cli/issues"
 },
 {
   "name": "Logo",
   "settings": [
      {
         "type": "image_picker",
         "id": "logo",
         "label": "Logo Image"
      },
      {
         "type": "range",
         "id": "logo_width",
         "min": 50,
         "max": 300,
         "step": 10,
         "unit": "px",
         "label": "Logo width",
         "default": 120
      },
      {
         "type": "image_picker",
         "id": "favicon",
         "label": "Favicon Image",
         "info": "Will be scaled down to 32 x 32px"
      }

   ]
 },
 {
   "name": "Layout",
   "settings": [
      {
         "type": "range",
         "id": "page_width",
         "min": 1000,
         "max": 1600,
         "step": 10,
         "default": 1440,
         "unit": "px",
         "label": "Page width"
      },
      {
         "type": "range",
         "id": "spacing_sections",
         "min": 0,
         "max": 100,
         "step": 4,
         "unit": "px",
         "label": "Space between sections",
         "default": 0
      }
   ]
 }
]