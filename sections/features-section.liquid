<div class="features-container">

    <div class="heading-container">
        <h6 class="subheading">{{ section.settings.subheading }}</h6>
        <h2 class="features-heading">{{ section.settings.heading}}</h2>
    </div>

    <div class="bestsellers-section">
        {% if section.settings.collection != blank %}
            {% for product in section.settings.collection.products limit: 4 %}
                {% render 'product-card', product: product %}
            {% endfor %}
        {% endif %}
    </div>

    <div class="collections-section">
        <h2 class="collections-heading">{{ section.settings.collections_heading }}</h2>

        <div class="collection-section-cards">
            {% for block in section.blocks %}
                <a href="{{ block.settings.collection.url }}">
                    <div class="collection-card-img">
                        {% if block.settings.image != blank %}
                            <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.collection.title}}" loading="lazy">
                        {% else %}
                            <img src="{{ block.settings.collections.featured_image | image_url: width: 500 }}" alt="{{ block.settings.collection.title}}" loading="lazy">
                        {% endif %}    
                    </div>
                    <div class="collection-card-text">{{ block.settings.collection.title }}</div>
                </a>
            {% endfor %}
        </div>
    </div>

</div>


{% schema %}
{
    "name": "Featured Section",
    "settings": [
        {
            "type": "text",
            "id": "subheading",
            "label": "Subheading",
            "default": "Featured Products"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Our Bestsellers"
        },
        {
            "type": "text",
            "id": "collections_heading",
            "label": "Collections Heading",
            "default": "Shop By Category"
        }
    ],
    "blocks": [
        {
            "type": "bestsellers-section",
            "name": "Bestsellers Grid",
            "settings": [
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "Select Best Sellers Collection"
                }
            ]
        },
        {
            "type": "collections-section",
            "name": "Category Picker",
            "settings": [
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "Select Category"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Custom Image"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Featured Section"
        }
    ]
} 
{% endschema %}