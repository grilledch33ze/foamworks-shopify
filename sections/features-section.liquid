<div class="features-container">

    <div class="heading-container">
        <h6 class="subheading">{{ section.settings.subheading }}</h6>
        <h2 class="features-heading">{{ section.settings.heading}}</h2>
    </div>

    <div class="bestsellers-section">
        {% for block in section.blocks %}
            {% if block.type == 'bestsellers-section' %}
                {% if block.settings.collection != blank %}
                    {% for product in block.settings.collection.products limit: 4 %}
                        {% render 'product-card', product: product %}
                    {% endfor %}
                {% endif %}
            {% endif %}
        {% endfor %}
    </div>

    <div class="collections-section">
        <h2 class="collections-heading">{{ section.settings.collections_heading }}</h2>

        <div class="collection-section-cards">
            {% for block in section.blocks %}
                {% if block.type == 'collections-section' %}
                    <a href="{{ block.settings.collection.url }}">
                        <div class="collection-card-img">
                            {%- if block.settings.image != blank -%}
                                {{ block.settings.image | image_url: width: 500 | image_tag: alt: block.settings.collection.title, loading: 'lazy' }}

                            {%- elsif block.settings.collection.featured_image != blank -%}
                                {{ block.settings.collection.featured_image | image_url: width: 500 | image_tag: alt: block.settings.collection.title, loading: 'lazy' }}

                            {%- else -%}
                                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                
                            {%- endif -%}
                        </div>
                        <div class="collection-card-text">{{ block.settings.collection.title }}</div>
                    </a>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>


{% schema %}
{
    "name": "Featured Section",
    "settings": [
        {
            "type": "text",
            "id": "subheading",
            "label": "Subheading",
            "default": "Featured Products"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Our Bestsellers"
        },
        {
            "type": "text",
            "id": "collections_heading",
            "label": "Collections Heading",
            "default": "Shop By Category"
        }
    ],
    "blocks": [
        {
            "type": "bestsellers-section",
            "name": "Bestsellers Grid",
            "settings": [
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "Select Best Sellers Collection"
                }
            ]
        },
        {
            "type": "collections-section",
            "name": "Category Picker",
            "settings": [
                {
                    "type": "collection",
                    "id": "collection",
                    "label": "Select Category"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Custom Image"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Featured Section"
        }
    ]
} 
{% endschema %}